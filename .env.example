# AutoMedia 环境变量配置
# 复制此文件为 .env 后按需填写。
#
# 当前链路为：
# 1. 前端 Header / Body
# 2. 服务端 .env 默认值（本文件）
# 3. 内置默认模型或 HTTP 400
#
# 分组与前端设置页保持一致：
# - 文本生成（LLM）
# - 分镜专用 LLM（无独立 .env，默认复用文本生成配置）
# - 图片生成
# - 视频生成
#
# 说明：
# - 前端填写了 API Key / Base URL / 模型时，会优先覆盖 .env
# - 前端留空时，后端回退到这里的对应分组配置
# - 豆包图片与豆包视频使用独立 API Key，不再混用

# 运行模式
DEBUG=true

# 默认 LLM 服务商
# 可选值：claude / openai / qwen / zhipu / gemini / siliconflow
DEFAULT_LLM_PROVIDER=claude

# 默认图片服务商
# 当前浏览器未保存图片设置时，会回退到这里。
# 可选值：siliconflow / doubao
DEFAULT_IMAGE_PROVIDER=siliconflow

# 默认视频服务商
# 当前浏览器未保存视频设置时，会回退到这里。
# 可选值：dashscope / kling / minimax / doubao
DEFAULT_VIDEO_PROVIDER=dashscope

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./automedia.db

# LLM：Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# LLM：OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM：阿里云 Qwen（DashScope OpenAI 兼容接口）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM：智谱 GLM
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# LLM：Google Gemini（OpenAI 兼容接口）
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# LLM：SiliconFlow（文本生成）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 图片生成：SiliconFlow
SILICONFLOW_IMAGE_API_KEY=
SILICONFLOW_IMAGE_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# 图片生成：豆包 / 火山方舟 Ark
# 火山方舟图片模型建议填写已发布的端点 ID（ep-...）
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_IMAGE_MODEL=ep-xxxxxxxxxxxxxxxx

# 视频：阿里云 DashScope
DASHSCOPE_VIDEO_API_KEY=
DASHSCOPE_VIDEO_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_VIDEO_MODEL=wan2.6-i2v-flash

# 视频：快手可灵 Kling
# 注意：前端/后端都要求格式为 access_key_id:secret_key
KLING_VIDEO_API_KEY=
KLING_VIDEO_BASE_URL=https://api.klingai.com
KLING_VIDEO_MODEL=kling-v2-master

# 视频：MiniMax 海螺视频
MINIMAX_VIDEO_API_KEY=
MINIMAX_VIDEO_BASE_URL=https://api.minimaxi.chat
MINIMAX_VIDEO_MODEL=video-01

# 视频：豆包 / 火山方舟 Ark
# 火山方舟视频模型建议填写已发布的端点 ID（ep-...）
DOUBAO_VIDEO_API_KEY=
DOUBAO_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VIDEO_MODEL=ep-yyyyyyyyyyyyyyyy

# 自定义兼容服务商时可使用的通用默认模型
DEFAULT_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
DEFAULT_VIDEO_MODEL=wan2.6-i2v-flash

# 安全：是否对用户自定义 Base URL 做 DNS 解析并拒绝内网 IP
# 开发环境通常可保持 false；生产环境建议按网络情况评估后开启
VALIDATE_BASE_URL_DNS=false

# 可选：自定义 FFmpeg / FFprobe 可执行文件路径
FFMPEG_PATH=
FFPROBE_PATH=
